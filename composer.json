{
    "name": "grafite/html",
    "description": "A handy way to generate some HTML without writing it.",
    "license": "MIT",
    "keywords": [
        "Laravel",
        "HTML",
        "LaravelCollective HTML"
    ],
    "authors": [
        {
            "name": "Matt Lantz",
            "email": "mattlantz@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "doctrine/dbal": "^2.5|^3.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/view": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "matthiasmullie/minify": "^1.3",
        "illuminate/collections": "^11.0|^12.0|^13.0",
        "badges/poser": "^3.1",
        "tempest/highlight": "^2.13"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "laravel/pint": "^1.10",
        "mockery/mockery": "^1.0",
        "mikey179/vfsstream": "^1.6",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "nunomaduro/phpinsights": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Grafite\\Html\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Grafite\\Html\\HtmlProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "check-style": "vendor/bin/pint --test",
        "fix-style": "vendor/bin/pint",
        "insights": "vendor/bin/phpinsights",
        "test": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --coverage-clover clover.xml && php coverage-checker.php clover.xml 50"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
